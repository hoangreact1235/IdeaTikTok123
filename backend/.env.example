# Example backend environment variables
# For YouTube Data API search
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional external search endpoints for TikTok and Douyin.
# Each endpoint should accept a query parameter and return { ideas: [...] }.
TIKTOK_SEARCH_URL=
DOUYIN_SEARCH_URL=

# Optional OpenAI API key for advanced script generation
OPENAI_API_KEY=your_openai_api_key_here

# Optional Gemini API key (Google AI Studio) for script generation fallback/provider selection
GEMINI_API_KEY=your_gemini_api_key_here
